# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=your_guild_id_for_dev_here

# Database
POSTGRES_PASSWORD=change_me_in_production
# DATABASE_URL is constructed automatically in docker-compose
# For local dev without Docker: uncomment and fill
# DATABASE_URL=postgresql://postgres:change_me_in_production@localhost:5432/discord_bot

# Logging
LOG_LEVEL=info

# Metrics (internal only in prod — no port exposed)
METRICS_PORT=9090

# Monitoring
GRAFANA_PASSWORD=change_me_in_production
GRAFANA_DOMAIN=grafana.yourdomain.com

# Environment
NODE_ENV=production
